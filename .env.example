# .env.example — copy to .env and fill in values

# Application
APP_NAME="Supa Kariakoo Spare Parts Centre"
DEBUG=True
#username=owner@supakariakoo.com&password=owner123
# Database (SQLite default — change to PostgreSQL URL for production)
DATABASE_URL=sqlite:///./ndorome_ims.db
DATABASE_SQLITE=True
# DATABASE_URL=postgresql://user:password@localhost:5432/ndorome_ims

# JWT — CHANGE THIS IN PRODUCTION!
SECRET_KEY=supa-kariakoo-spare-parts-super-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480

# CORS — comma-separated frontend origins
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]
